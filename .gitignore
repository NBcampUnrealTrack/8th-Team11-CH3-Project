# Unreal Engine 5 - .gitignore

# Generated project files
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vs/

# JetBrains Rider / IntelliJ (개인별 IDE 설정·캐시)
.idea/
*.DotSettings.user

# Compiled binaries
Binaries/
Plugins/*/Binaries/

# Build intermediates
Build/
Intermediate/
Plugins/*/Intermediate/

# Derived data cache (regenerated locally)
DerivedDataCache/

# Editor saved data (logs, backups, autosave)
Saved/

# Built map data (regenerated on cook)
*_BuiltData.uasset

# Platform-specific
*.xcodeproj
*.xcworkspace

# StarterContent (용량 크고 팀 작업 불필요)
Content/StarterContent/

# Fab 마켓플레이스 에셋 (개인 라이선스, 팀 공유 불가)
Content/_Fab/EasyComboBuffering/
